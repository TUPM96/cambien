WEB_PORT=8000
CSV_LOG=1
CAPTURE_EXPECTED_INTERVAL_SEC=13
CAPTURE_INTERVAL_BY_NODE=S1=10,S2=13

LORA_FREQUENCY_MHZ=433.0
LORA_SPI_BAUDRATE=1000000
LORA_SPI_CS=CE0
LORA_RESET_BCM=22
LORA_SPREADING_FACTOR=7
LORA_SIGNAL_BANDWIDTH=125000
LORA_CODING_RATE=5
LORA_PREAMBLE_LENGTH=8
LORA_SYNC_WORD=0x12
LORA_CRC=0
LORA_AGC=1
LORA_RX_TIMEOUT_SEC=0.2
LORA_LOST_SIGNAL_SEC=60
LORA_PRINT_PACKETS=1

FALLBACK_ZERO_INVALID_FIELDS=temperature,humidity,water_temperature,tds,ph

LCD_ENABLE=1
LCD_I2C_BUS=1
LCD_I2C_ADDR=0x27
LCD_COLS=16
LCD_ROWS=2
