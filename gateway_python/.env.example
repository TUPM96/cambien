############################
# MQTT (giống ESP32 gateway)
############################
MQTT_HOST=103.146.22.13
MQTT_PORT=1883
MQTT_USER=user1
MQTT_PASS=12345678
MQTT_TOPIC=sensor/lora/data

############################
# Web dashboard
############################
# Cổng web (nếu bận sẽ tự thử cổng kế tiếp)
WEB_PORT=8000

# Ghi lịch sử MQTT ra CSV trong thư mục web/data/ (0 = tắt)
CSV_LOG=1

# Chu kỳ gửi kỳ vọng của mỗi node (giây/gói) để tính mất gói trên bảng Capture
CAPTURE_EXPECTED_INTERVAL_SEC=13

# Override theo node, ví dụ: S1=10,S2=13
CAPTURE_INTERVAL_BY_NODE=S1=10,S2=13

############################
# LoRa (Raspberry Pi 4)
############################
# Tần số MHz. ESP32 đang dùng 433E6.
LORA_FREQUENCY_MHZ=433.0

# SPI chip select: CE0 hoặc CE1
LORA_SPI_CS=CE0

# GPIO reset cho module LoRa (BCM numbering, ví dụ GPIO22)
LORA_RESET_BCM=22

# Thời gian poll nhận gói (giây)
LORA_RX_TIMEOUT_SEC=0.2

# Nếu không có gói trong X giây => cảnh báo mất tín hiệu (ESP32: 60s)
LORA_LOST_SIGNAL_SEC=60

# Fallback khi node KHÔNG gửi validMask:
# coi các field có giá trị 0 là "mất dữ liệu" và tự tắt bit tương ứng trong valid_mask.
# Giá trị: danh sách phân tách bằng dấu phẩy, ví dụ: water_temperature,tds
FALLBACK_ZERO_INVALID_FIELDS=temperature,humidity,water_temperature,tds
