############################
# Web dashboard
############################
# Cổng web (nếu bận sẽ tự thử cổng kế tiếp)
WEB_PORT=8000

# Ghi lịch sử LoRa ra CSV trong thư mục web/data/ (0 = tắt)
CSV_LOG=1

# Chu kỳ gửi kỳ vọng của mỗi node (giây/gói) để tính mất gói trên bảng Capture
CAPTURE_EXPECTED_INTERVAL_SEC=13

# Override theo node, ví dụ: S1=10,S2=13
CAPTURE_INTERVAL_BY_NODE=S1=10,S2=13

############################
# LoRa (Raspberry Pi 4)
############################
# Tần số MHz. ESP32 đang dùng 433E6.
LORA_FREQUENCY_MHZ=433.0

# Tốc độ SPI giữa Raspberry Pi và module LoRa. 1MHz ổn định hơn khi dây dài/breadboard.
LORA_SPI_BAUDRATE=1000000

# SPI chip select: CE0 hoặc CE1
LORA_SPI_CS=CE0

# GPIO reset cho module LoRa (BCM numbering, ví dụ GPIO22)
LORA_RESET_BCM=22

# Radio params phải khớp node con ESP32 dùng sandeepmistry/LoRa:
# LoRa.begin(433E6), explicit header, SF7, BW125kHz, CR4/5, preamble 8, sync 0x12, CRC tắt.
LORA_SPREADING_FACTOR=7
LORA_SIGNAL_BANDWIDTH=125000
LORA_CODING_RATE=5
LORA_PREAMBLE_LENGTH=8
LORA_SYNC_WORD=0x12
LORA_CRC=0
LORA_AGC=1

# Thời gian poll nhận gói (giây)
LORA_RX_TIMEOUT_SEC=0.2

# Nếu không có gói trong X giây => cảnh báo mất tín hiệu (ESP32: 60s)
LORA_LOST_SIGNAL_SEC=60

# Fallback chỉ dùng khi node KHÔNG gửi validMask:
# coi các field có giá trị 0 là "mất dữ liệu" và tự tắt bit tương ứng trong valid_mask.
# Giá trị: danh sách phân tách bằng dấu phẩy, ví dụ: water_temperature,tds,ph
FALLBACK_ZERO_INVALID_FIELDS=temperature,humidity,water_temperature,tds,ph

############################
# LCD 16x2 I2C (PCF8574)
############################
# Cắm SDA=GPIO2 pin 3, SCL=GPIO3 pin 5. Bật I2C bằng raspi-config.
LCD_ENABLE=1
LCD_I2C_BUS=1
LCD_I2C_ADDR=0x27
LCD_COLS=16
LCD_ROWS=2
